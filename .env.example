# ==========================================================
#  Bulut — переменные окружения
#  Скопируйте этот файл в .env  (cp .env.example .env)
#  Подходит и для `npm run dev`, и для `docker compose up`.
# ==========================================================

# URL вашего проекта Supabase.
#  • Облако:      https://<project-ref>.supabase.co
#  • Локально:    http://localhost:54321   (после `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon-ключ (Settings → API → anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role ключ (Settings → API → service_role secret). СЕКРЕТ, только сервер!
# Нужен для полного удаления аккаунтов из админки (auth.users) и управления
# осиротевшими аккаунтами. Без него удаление недоступно (кнопка вернёт понятную ошибку).
SUPABASE_SERVICE_ROLE_KEY=

# ── Подтверждение email по OTP-коду при регистрации ───────────────
# Секрет для подписи одноразовых кодов (HMAC). Любая случайная строка ≥ 16 символов.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_SIGNING_SECRET=

# ── Infisical (env-management) — источник SMTP-ключей для писем ────
# Machine Identity (Universal Auth). SMTP_* читаются из проекта Infisical.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod
